# Copy to .env and fill in real values:  cp .env.example .env

# Map provider (e.g. Mapbox / Google Maps / MapTiler)
MAP_API_KEY=

# App
PORT=3000
NODE_ENV=development

# --- Vercel Blob ---
BLOB_STORE_ID=
BLOB_WEBHOOK_PUBLIC_KEY=
# Never commit. Get it with: vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=

# --- Auth & database ---
# Neon Postgres connection strings (Vercel/Neon integration provides these).
DATABASE_URL=
DATABASE_URL_UNPOOLED=
# Signs the session JWT. Generate with: openssl rand -base64 32
SESSION_SECRET=
# Google OAuth client (https://console.cloud.google.com/apis/credentials).
# Redirect URI: <APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public base URL, used to build the OAuth redirect. Empty = derive from request.
APP_URL=
