# Copy to .env and fill in real values:  cp .env.example .env

# Map provider (e.g. Mapbox / Google Maps / MapTiler)
MAP_API_KEY=

# App
PORT=3000
NODE_ENV=development

# --- Vercel Blob ---
BLOB_STORE_ID=
BLOB_WEBHOOK_PUBLIC_KEY=
# Never commit. Get it with: vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=
